    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH deleted_rows AS (\n  DELETE FROM gnote.messages m\n  USING gnote.topics t\n  WHERE m.topic_id = t.id\n    AND t.user_id = m.user_id\n    AND LOWER(t.title) = 'deleted messages'\n    AND m.deleted_at IS NOT NULL\n    AND m.deleted_at < NOW() - INTERVAL '7 days'\n  RETURNING\n    m.id,\n    m.user_id,\n    m.topic_id,\n    m.content,\n    m.created_at,\n    m.deleted_at,\n    m.message_type,\n    m.file_name\n)\n\nSELECT\n  COUNT(*) AS permanently_deleted_count,\n  NOW() AS purge_executed_at\nFROM deleted_rows;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
