      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst state = input.state\n  ? String(input.state).trim()\n  : 'no_state';\n\nreturn [\n  {\n    json: {\n      ...input,\n      state\n    }\n  }\n];"
