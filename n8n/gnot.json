        "operation": "executeQuery",
        "query": "WITH upsert_user AS (\n  INSERT INTO gnote.users (\n    id,\n    name,\n    first_visit,\n    last_visit,\n    all_messages\n  )\n  VALUES (\n    {{ $(\"Telegram Trigger\").first().json.message.from.id }},\n    '{{ $(\"Telegram Trigger\").first().json.message.from.first_name.replace(/'/g, \"''\") }}',\n    NOW(),\n    NOW(),\n    0\n  )\n  ON CONFLICT (id)\n  DO UPDATE SET\n    name = EXCLUDED.name,\n    last_visit = NOW()\n  RETURNING id\n),\ninsert_pending AS (\n  INSERT INTO gnote.pending_messages (\n    user_id,\n    message,\n    created_at\n  )\n  VALUES (\n    {{ $(\"Telegram Trigger\").first().json.message.from.id }},\n    '{{ $(\"Telegram Trigger\").first().json.message.text.replace(/'/g, \"''\") }}',\n    NOW()\n  )\n  RETURNING id, user_id, message, created_at\n)\nSELECT \n  id,\n  user_id,\n  message,\n  created_at\nFROM insert_pending;",
