          "id": "MuKN7jUvqjq4touw",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH moved AS (\n  DELETE FROM gnote.pending_messages\n  WHERE user_id = {{ $json.user_id }}\n  RETURNING\n    id AS pending_id,\n    user_id,\n    message,\n    created_at\n),\n\ninserted AS (\n  INSERT INTO gnote.messages (\n    user_id,\n    topic_id,\n    content,\n    created_at\n  )\n  SELECT\n    moved.user_id,\n    {{ $json.id }},\n    moved.message,\n    moved.created_at\n  FROM moved\n  RETURNING\n    id,\n    user_id,\n    topic_id,\n    content,\n    created_at\n),\n\nstats AS (\n  SELECT\n    COUNT(*) AS saved_count\n  FROM inserted\n)\n\nSELECT\n  stats.saved_count,\n  {{ $json.user_id }}::BIGINT AS user_id,\n  {{ $json.id }}::BIGINT AS topic_id,\n  {{ $(\"Telegram Trigger\").first().json.message.chat.id }}::BIGINT AS chat_id,\n  '{{ $json.title.replace(/'/g, \"''\") }}' AS topic_title,\n  (\n    SELECT COALESCE(u.all_messages, 0) + stats.saved_count\n    FROM gnote.users u\n    WHERE u.id = {{ $json.user_id }}\n  ) AS user_all_messages\nFROM stats;",
        "options": {}
      },
