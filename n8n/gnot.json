    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH inserted AS (\n  INSERT INTO gnote.topics (title, user_id)\n  VALUES (\n    '{{ $(\"Telegram Trigger\").first().json.message.text.replace(/'/g, \"''\") }}',\n    {{ $(\"Telegram Trigger\").first().json.message.from.id }}\n  )\n  ON CONFLICT DO NOTHING\n  RETURNING id, title, user_id\n),\nexisting AS (\n  SELECT id, title, user_id\n  FROM gnote.topics\n  WHERE user_id = {{ $(\"Telegram Trigger\").first().json.message.from.id }}\n    AND LOWER(title) = LOWER('{{ $(\"Telegram Trigger\").first().json.message.text.replace(/'/g, \"''\") }}')\n  LIMIT 1\n),\nclear_state AS (\n  DELETE FROM gnote.user_state\n  WHERE user_id = {{ $(\"Telegram Trigger\").first().json.message.from.id }}\n)\nSELECT *\nFROM inserted\nUNION ALL\nSELECT *\nFROM existing\nLIMIT 1;",
        "options": {}
      },
