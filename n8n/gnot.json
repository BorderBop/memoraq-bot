    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nif (!input.callback_query) {\n  throw new Error('This node expects callback_query, but received message');\n}\n\nconst data = input.callback_query.data;\n// пример: select_topic:18\n\nconst topicId = Number(data.split(':')[1]);\nconst userId = input.callback_query.from.id;\n\nreturn [\n  {\n    json: {\n      user_id: userId,\n      topic_id: topicId,\n      callback_query_id: input.callback_query.id,\n      chat_id: input.callback_query.from.id\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -352,
        -96
      ],
      "id": "02ba8071-70a7-4fb4-9c7a-44ecc271ae37",
      "name": "parse selected topic"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH selected_topic AS (\n  SELECT id, title, user_id\n  FROM gnote.topics\n  WHERE id = {{ $json.topic_id }}\n    AND user_id = {{ $json.user_id }}\n  LIMIT 1\n),\n\nmoved AS (\n  DELETE FROM gnote.pending_messages\n  WHERE user_id = {{ $json.user_id }}\n    AND EXISTS (SELECT 1 FROM selected_topic)\n  RETURNING\n    id AS pending_id,\n    user_id,\n    message,\n    created_at\n),\n\ninserted AS (\n  INSERT INTO gnote.messages (\n    user_id,\n    topic_id,\n    content,\n    created_at\n  )\n  SELECT\n    moved.user_id,\n    {{ $json.topic_id }},\n    moved.message,\n    moved.created_at\n  FROM moved\n  RETURNING\n    id,\n    user_id,\n    topic_id,\n    content,\n    created_at\n),\n\nstats AS (\n  SELECT\n    COUNT(*) AS saved_count\n  FROM inserted\n)\n\nSELECT\n  stats.saved_count,\n  {{ $json.user_id }}::BIGINT AS user_id,\n  {{ $json.topic_id }}::BIGINT AS topic_id,\n  {{ $json.chat_id }}::BIGINT AS chat_id,\n  '{{ $json.callback_query_id }}' AS callback_query_id,\n  COALESCE((SELECT title FROM selected_topic), '') AS topic_title,\n  (\n    SELECT COALESCE(u.all_messages, 0) + stats.saved_count\n    FROM gnote.users u\n    WHERE u.id = {{ $json.user_id }}\n  ) AS user_all_messages\nFROM stats;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -160,
        -96
      ],
      "id": "e6b15751-a3bc-43d4-950e-f69d0f97e0db",
      "name": "move pending to messages",
      "credentials": {
