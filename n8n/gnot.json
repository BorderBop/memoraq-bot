      "parameters": {
        "jsCode": "// Получаем данные из Postgres\nconst items = $input.all();\n\nconst buttons = items.map(item => ({\n  text: `📁 ${item.json.title}`,\n  callback_data: `select_topic:${item.json.id}`\n}));\n\n// Кнопка создания нового\nbuttons.push({\n  text: '➕ Создать новый топик',\n  callback_data: 'action:create_new'\n});\n\n// Группируем по 2 в ряд\nconst rows = [];\nwhile (buttons.length) {\n  rows.push(buttons.splice(0, 2));\n}\n\n\nreturn [\n  {\n    json: {\n      chat_id: $('Telegram Trigger').first().json.message.from.id,\n      inline_keyboard: rows\n    }\n  }\n];"
      },
