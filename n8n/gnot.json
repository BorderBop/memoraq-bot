    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH new_topic AS (\n  INSERT INTO gnote.topics (title, user_id)\n  VALUES (\n    '{{ $(\"Telegram Trigger\").item.json.message.text.replace(/'/g, \"''\") }}',\n    {{ $(\"Telegram Trigger\").item.json.message.from.id }}\n  )\n  ON CONFLICT DO NOTHING\n  RETURNING id, title, user_id\n),\nclear_state AS (\n  DELETE FROM gnote.user_state\n  WHERE user_id = {{ $(\"Telegram Trigger\").item.json.message.from.id }}\n)\nSELECT *\nFROM new_topic;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
