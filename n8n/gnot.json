    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH upsert_user AS (\n  INSERT INTO gnote.users (\n    id,\n    name,\n    first_visit,\n    last_visit,\n    all_messages\n  )\n  VALUES (\n    {{ $(\"Telegram Trigger\").item.json.message.from.id }},\n    '{{ $(\"Telegram Trigger\").item.json.message.from.first_name.replace(/'/g, \"''\") }}',\n    NOW(),\n    NOW(),\n    1\n  )\n  ON CONFLICT (id)\n  DO UPDATE SET\n    name = EXCLUDED.name,\n    last_visit = NOW(),\n    all_messages = COALESCE(gnote.users.all_messages, 0) + 1\n  RETURNING id\n),\ninsert_pending AS (\n  INSERT INTO gnote.pending_messages (\n    user_id,\n    message,\n    created_at\n  )\n  VALUES (\n    {{ $(\"Telegram Trigger\").item.json.message.from.id }},\n    '{{ $(\"Telegram Trigger\").item.json.message.text.replace(/'/g, \"''\") }}',\n    NOW()\n  )\n  RETURNING id, user_id, message, created_at\n)\nSELECT *\nFROM insert_pending;",
        "options": {}
