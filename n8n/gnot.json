    {
      "parameters": {
        "content": " Main Event Router\n\nThis block receives all incoming Telegram updates and routes them by event type.\n- `message` — regular user text message\n- `callback_query` — inline keyboard button click\n",
        "height": 240
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -928,
        -256
      ],
      "id": "f1d19614-d7d4-41cb-92e8-b1c7d4e72bda",
      "name": "Sticky Note"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  t.id,\n  t.title,\n  COUNT(m.id) AS messages_count\nFROM gnote.topics t\nLEFT JOIN gnote.messages m\n  ON m.topic_id = t.id\n  AND m.user_id = t.user_id\nWHERE t.user_id = {{ $json.message.from.id }}\nGROUP BY t.id, t.title\nORDER BY t.title ASC;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -352,
        80
      ],
      "id": "d974f535-b021-4da2-83cd-daabe9e15a24",
      "name": "get topics with counts",
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "MuKN7jUvqjq4touw",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst validTopics = items.filter(item => item.json.id && item.json.title);\n\nif (validTopics.length === 0) {\n  return [\n    {\n      json: {\n        chat_id: $('Telegram Trigger').first().json.message.chat.id,\n        text: \"У тебя пока нет топиков.\\n\\nНажми ➕ Создать новый топик, когда будешь сохранять сообщение.\"\n      }\n    }\n  ];\n}\n\nconst lines = validTopics.map((item, index) => {\n  const title = item.json.title;\n  const count = Number(item.json.messages_count || 0);\n\n  return `${index + 1}. 📁 ${title} — ${count} ${count === 1 ? 'message' : 'messages'}`;\n});\n\nreturn [\n  {\n    json: {\n      chat_id: $('Telegram Trigger').first().json.message.chat.id,\n      text: `📚 Твои топики:\\n\\n${lines.join('\\n')}`\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
